{
  "session": {
    "restore_unsaved_buffers": false,
    "trust_all_worktrees": true
  },
  "default_open_behavior": "new_window",
  "language_models": {
    "opencode": {
      "show_free_models": true,
      "show_zen_models": true,
    },
  },
  "cli_default_open_behavior": "new_window",
  "git_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
  },
  "theme": "Catppuccin Mocha",
  "show_edit_predictions": true,
  "auto_update": false,
  "edit_predictions": {
    "mode": "eager",
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "inline_assistant_model": {
      "provider": "opencode",
      "model": "go/deepseek-v4-flash",
    },
    "default_profile": "write",
    "default_model": {
      "effort": "xhigh",
      "enable_thinking": true,
      "provider": "opencode",
      "model": "go/deepseek-v4-flash",
    },
  },
  "languages": {
    "Rust": {
      "show_edit_predictions": false,
    },
    "V": {
      "show_edit_predictions": false,
      "tab_size": 4,
      "formatter": {
        "external": {
          "command": "v",
          "arguments": ["fmt"],
        },
      },
    },
    "Zig": {
      "show_edit_predictions": false,
    },
    "Odin": {
      "show_edit_predictions": false,
    },
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "buffer_font_size": 16.0,
  "autosave": { "after_delay": { "milliseconds": 500 } },
  "terminal": { "toolbar": { "breadcrumbs": false } },
  "restore_on_startup": "empty_tab",
  "extend_comment_on_newline": false,
  "auto_signature_help": true,
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  }
}
